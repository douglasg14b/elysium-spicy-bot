{
    "name": "discord-spicy-bot",
    "version": "1.0.0",
    "description": "",
    "main": "src/bot.ts",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "start": "node dist/bot.js",
        "dev": "cross-env TSX=true dotenvx run --env-file=.env.local -- tsx watch src/bot.ts",
        "test": "vitest run",
        "test:birthday-live": "cross-env RUN_OPENAI_BIRTHDAY_TESTS=1 dotenvx run --env-file=.env.local -- vitest run --config vitest.live.config.ts src/features/birthday-tracker/__tests__/birthdayAnnouncements.live.test.ts",
        "test:intent-live": "cross-env RUN_OPENAI_INTENT_TESTS=1 dotenvx run --env-file=.env.local -- vitest run --config vitest.live.config.ts",
        "start:dev:docker": "docker compose -f docker-compose.dev.yml --env-file .env.local up --build",
        "migrate:latest": "tsx src/features-system/data-persistence/migrate.ts",
        "migrate:latest:dev": "dotenvx run --env-file=.env.local -- tsx src/features-system/data-persistence/migrate.ts",
        "clean": "rimraf dist",
        "github-plan": "tsx github-plan-cli/src/cli.ts",
        "github-plan:plan-local": "dotenvx run --env-file=.env.local -- tsx github-plan-cli/src/cli.ts plan run-local"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@cacheable/node-cache": "^2.0.0",
        "@eicode/result-pattern": "^2.3.2",
        "@octokit/rest": "^22.0.1",
        "@openai/agents": "^0.3.7",
        "@openai/guardrails": "^0.2.1",
        "better-sqlite3": "^12.2.0",
        "citty": "^0.2.1",
        "commandkit": "1.2.0-rc.3",
        "discord.js": "^14.23.2",
        "env-var": "^7.5.0",
        "kysely": "^0.28.5",
        "node-cache": "5.1.2",
        "openai": "^6.16.0",
        "pathe": "^2.0.3",
        "pg": "^8.16.3",
        "simple-git": "^3.33.0",
        "zod": "^4.3.5"
    },
    "devDependencies": {
        "@dotenvx/dotenvx": "^1.49.0",
        "@tsconfig/recommended": "^1.0.10",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^24.3.0",
        "@types/pg": "^8.15.5",
        "@vitest/ui": "^3.2.4",
        "cross-env": "^10.1.0",
        "nodemon": "^3.1.10",
        "rimraf": "^6.0.1",
        "tsx": "^4.20.4",
        "typescript": "^5.9.2",
        "vitest": "^3.2.4"
    },
    "packageManager": "pnpm@9.15.9+sha256.cf86a7ad764406395d4286a6d09d730711720acc6d93e9dce9ac7ac4dc4a28a7"
}
